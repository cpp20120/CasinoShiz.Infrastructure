{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "MinIO scrape",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "VictoriaMetrics"},
      "targets": [{"expr": "max(up{job=\"minio\"})", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Online nodes",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "VictoriaMetrics"},
      "targets": [{"expr": "sum(minio_cluster_health_nodes_online_count{job=\"minio\"})", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Offline nodes",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "VictoriaMetrics"},
      "targets": [{"expr": "sum(minio_cluster_health_nodes_offline_count{job=\"minio\"})", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Drive usage",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "VictoriaMetrics"},
      "targets": [{"expr": "100 * sum(minio_node_drive_used_bytes{job=\"minio\"}) / clamp_min(sum(minio_node_drive_used_bytes{job=\"minio\"}) + sum(minio_node_drive_free_bytes{job=\"minio\"}), 1)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 70}, {"color": "red", "value": 90}]}}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "S3 requests",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "VictoriaMetrics"},
      "targets": [{"expr": "sum(rate(minio_s3_requests_total{job=\"minio\"}[5m]))", "legendFormat": "requests/s", "refId": "A"}, {"expr": "sum(rate(minio_s3_requests_errors_total{job=\"minio\"}[5m]))", "legendFormat": "errors/s", "refId": "B"}],
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "S3 traffic",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "VictoriaMetrics"},
      "targets": [{"expr": "sum(rate(minio_s3_traffic_received_bytes{job=\"minio\"}[5m]))", "legendFormat": "received", "refId": "A"}, {"expr": "sum(rate(minio_s3_traffic_sent_bytes{job=\"minio\"}[5m]))", "legendFormat": "sent", "refId": "B"}],
      "fieldConfig": {"defaults": {"unit": "Bps", "min": 0}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Drive space",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "VictoriaMetrics"},
      "targets": [{"expr": "sum(minio_node_drive_used_bytes{job=\"minio\"})", "legendFormat": "used", "refId": "A"}, {"expr": "sum(minio_node_drive_free_bytes{job=\"minio\"})", "legendFormat": "free", "refId": "B"}],
      "fieldConfig": {"defaults": {"unit": "bytes", "min": 0}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Bucket usage",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "VictoriaMetrics"},
      "targets": [{"expr": "sum by (bucket) (minio_bucket_usage_total_bytes{job=\"minio\"})", "legendFormat": "{{bucket}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes", "min": 0}, "overrides": []}
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["casinoshiz", "victoriametrics", "minio", "object-storage"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "CasinoShiz · MinIO Object Storage",
  "uid": "casinoshiz-minio-vm",
  "version": 1
}
