nment:\n  NAMESPACE=data\n  BACKUP_PVC=data-backups\n\nThe production database is never overwritten unless --target explicitly names it.\nEOF\n}\n\nwhile [ "$#" -gt 0 ]; do\n  case "$1" in\n    --backup) BACKUP="$2"; shift 2 ;;\n    --database) DATABASE="$2"; shift 2 ;;\n    --target) TARGET_DATABASE="$2"; shift 2 ;;\n    --drop-target) DROP_TARGET=true; shift ;;\n    --keep-job) KEEP_JOB=true; shift ;;\n    -h|--help) usage; exit 0 ;;\n    *) die "unknown argument: $1" ;;\n  esac\ndone\n\ncase "$DATABASE" in\n  *[!a-zA-Z0-9_]*|\'\') die "invalid database name: $DATABASE" ;;\nesac\n\nif [ "$BACKUP" = latest ]; then\n  BACKUP="$(latest_backup_dir postgres)"\nfi\n\nif [ -z "$TARGET_DATABASE" ]; then\n  TARGET_DATABASE="${DATABASE}_restore_$(date -u +%Y%m%d%H%M%S)"\nfi\n\ncase "$TARGET_DATABASE" in\n  *[!a-zA-Z0-9_]*|\'\') die "invalid target database name: $TARGET_DATABASE" ;;\nesac\n\nJOB="postgres-restore-$(date +%s)"\nDROP_SQL=""\nif [ "$DROP_TARGET" = true ]; then\n  DROP_SQL="DROP DATABASE IF EXISTS \\"$TARGET_DATABASE\\" WITH (FORCE);"\nfi\n\ninfo "Restoring PostgreSQL $DATABASE from $BACKUP into $TARGET_DATABASE"\n\ncat <<YAML | kubectl apply -f -\napiVersion: batch/v1\nkind: Job\nmetadata:\n  name: $JOB\n  namespace: $NAMESPACE\n  labels:\n    app.kubernetes.io/name: postgres-restore\nspec:\n  backoffLimit: 0\n  ttlSecondsAfterFinished: 3600\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/name: postgres-restore\n    spec:\n      restartPolicy: Never\n      containers:\n        - name: restore\n          image: postgres:16-alpine\n          env:\n            - name: PGHOST\n              value: postgres.data.svc.cluster.local\n            - name: PGUSER\n              value: postgres\n            - name: PGPASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: data-secrets\n                  key: postgres-superuser-password\n          command:\n            - /bin/sh\n            - -ec\n            - |\n              backup_dir="/backup/postgres/$BACKUP"\n              dump="\\$backup_dir/$DATABASE.dump"\n              test -s "\\$dump"\n\n              if test -f "\\$backup_dir/SHA256SUMS"; then\n                cd "\\$backup_dir"\n                sha256sum -c SHA256SUMS\n              fi\n\n              psql --dbname=postgres --set=ON_ERROR_STOP=1 <<\'SQL\'\n              $DROP_SQL\nSQL\n\n              exists="\\$(psql --dbname=postgres --tuples-only --no-align \\\n                --command "SELECT 1 FROM pg_database WHERE datname = \'$TARGET_DATABASE\'")"\n              test -z "\\$exists" || {\n                echo "target database already exists: $TARGET_DATABASE" >&2\n                exit 1\n              }\n\n              createdb "$TARGET_DATABASE"\n              pg_restore \\\n                --exit-on-error \\\n                --no-owner \\\n                --no-privileges \\\n                --dbname="$TARGET_DATABASE" \\\n                "\\$dump"\n\n              tables="\\$(psql --dbname="$TARGET_DATABASE" --tuples-only --no-align \\\n                --command "SELECT count(*) FROM pg_catalog.pg_tables WHERE schemaname NOT IN (\'pg_catalog\',\'information_schema\')")"\n              test "\\$tables" -gt 0\n              echo "restored database=$TARGET_DATABASE tables=\\$tables"\n          volumeMounts:\n            - name: backups\n              mountPath: /backup\n              readOnly: true\n      volumes:\n        - name: backups\n          persistentVolumeClaim:\n            claimName: $BACKUP_PVC\nYAML\n\nwait_job "$JOB" 900s\n\nif [ "$KEEP_JOB" != true ]; then\n  kubectl -n "$NAMESPACE" delete job "$JOB" --wait=false >/dev/null\nfi\n\ninfo "PostgreSQL restore completed: $TARGET_DATABASE"\n'}, 'restore-redis.sh': {'interpreter': 'sh', 'body': 'set -eu\n\nset -eu\n\nNAMESPACE="${NAMESPACE:-data}"\nBACKUP_PVC="${BACKUP_PVC:-data-backups}"\n\ndie() {\n  printf \'error: %s\n\' "$*" >&2\n  exit 1\n}\n\ninfo() {\n  printf \'==> %s\n\' "$*"\n}\n\nreq