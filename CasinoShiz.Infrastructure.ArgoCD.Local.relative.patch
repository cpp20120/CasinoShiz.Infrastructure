diff -ruN '--exclude=.git' '--exclude=.task' a/argocd/cmp-plugin.yaml b/argocd/cmp-plugin.yaml
--- a/argocd/cmp-plugin.yaml	1970-01-01 00:00:00.000000000 +0000
+++ b/argocd/cmp-plugin.yaml	2026-07-17 16:48:04.000000000 +0000
@@ -0,0 +1,30 @@
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: argocd-cmp-sops-kustomize
+  namespace: argocd
+data:
+  plugin.yaml: |
+    apiVersion: argoproj.io/v1alpha1
+    kind: ConfigManagementPlugin
+    metadata:
+      name: sops-kustomize
+    spec:
+      version: v1.0
+      discover:
+        fileName: kustomization.yaml
+      generate:
+        command: [/bin/sh, -ec]
+        args:
+          - |
+            workdir=$(mktemp -d)
+            trap 'rm -rf "$workdir"' EXIT
+            cp -a . "$workdir/repo"
+            find "$workdir/repo" -type f \( -name '*.secret.yaml' -o -name '*.secret.yml' \) -exec sh -ec '
+              for file do
+                sops --decrypt --output "$file.dec" "$file"
+                mv "$file.dec" "$file"
+              done
+            ' sh {} +
+            cd "$workdir/repo"
+            kustomize build .
