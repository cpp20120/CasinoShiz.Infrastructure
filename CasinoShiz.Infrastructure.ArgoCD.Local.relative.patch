se "$1" in\n    --backup) BACKUP="$2"; shift 2 ;;\n    --mode) MODE="$2"; shift 2 ;;\n    --confirm) CONFIRM="$2"; shift 2 ;;\n    --keep-job) KEEP_JOB=true; shift ;;\n    -h|--help) usage; exit 0 ;;\n    *) die "unknown argument: $1" ;;\n  esac\ndone\n\nif [ "$BACKUP" = latest ]; then\n  BACKUP="$(latest_backup_dir redis)"\nfi\n\ncase "$MODE" in\n  verify)\n    JOB="redis-restore-verify-$(date +%s)"\n    info "Verifying Redis backup $BACKUP in an isolated instance"\n\n    cat <<YAML | kubectl apply -f -\napiVersion: batch/v1\nkind: Job\nmetadata:\n  name: $JOB\n  namespace: $NAMESPACE\nspec:\n  backoffLimit: 0\n  ttlSecondsAfterFinished: 3600\n  template:\n    spec:\n      restartPolicy: Never\n      containers:\n        - name: verify\n          image: redis:7-alpine\n          command:\n            - /bin/sh\n            - -ec\n            - |\n              src="/backup/redis/$BACKUP"\n              test -s "\\$src/dump.rdb"\n              mkdir -p /restore\n              cp "\\$src/dump.rdb" /restore/dump.rdb\n\n              if test -f "\\$src/SHA256SUMS"; then\n                cd "\\$src"\n                sha256sum -c SHA256SUMS || true\n              fi\n\n              redis-check-rdb /restore/dump.rdb\n              redis-server \\\n                --dir /restore \\\n                --dbfilename dump.rdb \\\n                --appendonly no \\\n                --protected-mode no \\\n                --bind 127.0.0.1 \\\n                --daemonize yes\n\n              for attempt in \\$(seq 1 30); do\n                redis-cli -h 127.0.0.1 ping >/dev/null 2>&1 && break\n                sleep 1\n              done\n\n              redis-cli -h 127.0.0.1 ping\n              keys="\\$(redis-cli -h 127.0.0.1 dbsize | tr -d \'\\r\')"\n              echo "verified backup=$BACKUP keys=\\$keys"\n              redis-cli -h 127.0.0.1 shutdown nosave\n          volumeMounts:\n            - name: backups\n              mountPath: /backup\n              readOnly: true\n      volumes:\n        - name: backups\n          persistentVolumeClaim:\n            claimName: $BACKUP_PVC\nYAML\n\n    wait_job "$JOB" 600s\n    if [ "$KEEP_JOB" != true ]; then\n      kubectl -n "$NAMESPACE" delete job "$JOB" --wait=false >/dev/null\n    fi\n    ;;\n\n  replace)\n    [ "$CONFIRM" = REPLACE_REDIS ] || die \\\n      "--mode replace requires --confirm REPLACE_REDIS"\n\n    info "Scaling Redis StatefulSet to zero"\n    kubectl -n "$NAMESPACE" scale statefulset redis --replicas=0\n    kubectl -n "$NAMESPACE" wait \\\n      --for=delete pod/redis-0 \\\n      --timeout=180s || true\n\n    POD="redis-restore-copy-$(date +%s)"\n    info "Replacing production Redis data from backup $BACKUP"\n    cat <<YAML | kubectl apply -f -\napiVersion: v1\nkind: Pod\nmetadata:\n  name: $POD\n  namespace: $NAMESPACE\nspec:\n  restartPolicy: Never\n  containers:\n    - name: restore\n      image: redis:7-alpine\n      command:\n        - /bin/sh\n        - -ec\n        - |\n          src="/backup/redis/$BACKUP"\n          test -s "\\$src/dump.rdb"\n          redis-check-rdb "\\$src/dump.rdb"\n\n          find /redis-data -mindepth 1 -maxdepth 1 -exec rm -rf {} +\n          cp "\\$src/dump.rdb" /redis-data/dump.rdb\n\n          if test -d "\\$src/appendonlydir"; then\n            cp -a "\\$src/appendonlydir" /redis-data/\n          fi\n\n          chown -R 999:999 /redis-data\n          echo "production Redis PVC replaced"\n      volumeMounts:\n        - name: backups\n          mountPath: /backup\n          readOnly: true\n        - name: redis-data\n          mountPath: /redis-data\n  volumes:\n    - name: backups\n      persistentVolumeClaim:\n        claimName: $BACKUP_PVC\n    - name: redis-data\n      persistentVolumeClaim:\n        claimName: data-redis-0\nYAML\n\n    kubectl -n "$NAMESPACE" wait \\\n      --for=jsonpath=\'{.status.phase}\'=Succeeded \\\n      "pod/$POD" \\\n      --timeout=300s || {\n        kubectl -n "$NAMESPACE" logs "$POD" || true\n        die "Redis restore copy failed; StatefulSet remains scaled down"\n      }\n    kubectl -n "$NAMESPACE" logs "$POD"\n    kubectl -n "$NAMESPACE" delete pod "$POD" --wait=false >/dev/null\n\n    info "Starting Redis StatefulSet"\n    kubectl -n "$NAMESPACE" scale statefulset redis --replicas=1\n    kubectl -n "$NAMESPACE" rollout status statefulset/redis --timeout=300s\n    ;;\n\n  *) die "mode must be verify or replace" ;;\nesac\n'}, 'restore-smoke-test.sh': {'interpreter': 'sh', 'body': 'set -eu\n\nSCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"\n\nPOSTGRES_DATABASE="${POSTGRES_DATABASE:-backend}"\nCLICKHOUSE_DATABASE="${CLICKHOUSE_DATABASE:-cazinoshiz}"\nMINIO_BUCKET="${MINIO_BUCKET:-}"\n\ncleanup_postgres=""\ncleanup_clickhouse=""\n\ntimestamp="$(date -u +%Y%m%d%H%M%S)"\npg_target="${POSTGRES_DATABASE}_restore_smoke_${timestamp}"\nch_target="${CLICKHOUSE_DATABASE}_restore_smoke_${timestamp}"\n\necho "==> PostgreSQL restore smoke test"\n"$SCRIPT_DIR/restore-postgres.sh" \\\n  --database "$POSTGRES_DATABASE" \\\n  --target "$pg_target"\ncleanup_postgres="$pg_target"\n\necho "==> ClickHouse restore smoke test"\n"$SCRIPT_DIR/restore-clickhouse.sh" \\\n  --source-db "$CLICKHOUSE_DATABASE" \\\n  --target-db "$ch_target"\ncleanup_clickhouse="$ch_target"\n\necho "==> Redis restore verification"\n"$SCRIPT_DIR/restore-redis.sh" --mode verify\n\nif [ -n "$MINIO_BUCKET" ]; then\n  echo "==> MinIO restore smoke test"\n  "$SCRIPT_DIR/restore-minio.sh" \\\n    --bucket "$MINIO_BUCKET" \\\n    --target-bucket "${MINIO_BUCKET}-restore-smoke-${timestamp}"\nelse\n  echo "==> MINIO_BUCKET is unset; skipping MinIO restore smoke test"\nfi\n\ncat <<EOF\n\nRestore smoke tests completed.\n\nTemporary databases were intentionally retained for inspection:\n  PostgreSQL: $cleanup_postgres\n  ClickHouse: $cleanup_clickhouse\n\nDelete after inspection:\n\n  kubectl -n data exec statefulset/postgres -- \\\n    dropdb --username postgres "$cleanup_postgres"\n\n  kubectl -n data exec statefulset/clickhouse -- \\\n    clickhouse-client --query \\\n    \'DROP DATABASE IF EXISTS \\`$cleanup_clickhouse\\`\'\nEOF\n'}, 'sops-check.sh': {'interpreter': 'sh', 'body': 'set -eu\n\ndie() {\n  printf \'error: %s\\n\' "$*" >&2\n  exit 1\n}\n\ncommand -v sops >/dev/null 2>&1 || die "sops is required"\n[ -f .sops.yaml ] || die ".sops.yaml is missing; run ./scripts/sops-init.sh"\n\ncase "$(grep -E \'^[[:space:]]*age:[[:space:]]*age1\' .sops.yaml | wc -l | tr -d \' \')" in\n  0) die ".sops.yaml does not contain an age recipient" ;;\nesac\n\nfailed=0\nfound=0\n\n# Git-tracked secret manifests only. Examples and Helm templates are excluded.\nfiles="$(\n  git ls-files \\\n    \'*secret.yaml\' \\\n    \'*secret.yml\' \\\n    \'*.secret.yaml\' \\\n    \'*.secret.yml\' \\\n  | grep -Ev \\\n      \'(^|/)(examples?|templates?)/|[.]example([.]|$)|secret-example[.]ya?ml$\' \\\n  || true\n)"\n\nfor file in $files; do\n  found=$((found + 1))\n\n  if ! grep -q \'^kind:[[:space:]]*Secret[[:space:]]*$\' "$file"; then\n    printf \'not a Kubernetes Secret: %s\\n\' "$file" >&2\n    failed=1\n    continue\n  fi\n\n  if ! grep -q \'^sops:[[:space:]]*$\' "$file"; then\n    printf \'missing SOPS metadata: %s\\n\' "$file" >&2\n    failed=1\n    continue\n  fi\n\n  if ! grep -q \'ENC\\[AES256_GCM\' "$file"; then\n    printf \'plaintext or malformed SOPS secret: %s\\n\' "$file" >&2\n    failed=1\n    continue\n  fi\n\n  # MAC/decryption validation. Does not print plaintext.\n  if ! sops --decrypt "$file" >/dev/null; then\n    printf \'cannot decrypt or authenticate: %s\\n\' "$file" >&2\n    failed=1\n    continue\n  fi\n\n  printf \'ok: %s\\n\' "$file"\ndone\n\nif [ "$found" -eq 0 ]; then\n  printf \'warning: no tracked production *.secret.yaml files found\\n\' >&2\nfi\n\n[ "$failed" -eq 0 ] || die "SOPS validation failed"\n'}, 'sops-create-app-secret.sh': {'interpreter': 'sh', 'body': 'set -eu\n\nENV_FILE="${1:-}"\nOUTPUT="${2:-clusters/production/casinoshiz/casinoshiz.secret.yaml}"\nNAMESPACE="${NAMESPACE:-casinoshiz}"\nNAME="${NAME:-casinoshiz-secrets}"\n\ndie() {\n  printf \'error: %s\\n\' "$*" >&2\n  exit 1\n}\n\ncommand -v kubectl >/dev/null 2>&1 || die "kubectl is required"\ncommand -v sops >/dev/null 2>&1 || die "sops is required"\n[ -f .sops.yaml ] || die ".sops.yaml missing; run ./scripts/sops-init.sh"\n[ -n "$ENV_FILE" ] || die "usage: $0 path/to/production.env [output.secret.yaml]"\n[ -f "$ENV_FILE" ] || die "env file not found: $ENV_FILE"\n\nmkdir -p "$(dirname "$OUTPUT")"\n\nkubectl create secret generic "$NAME" \\\n  --namespace "$NAMESPACE" \\\n  --from-env-file="$ENV_FILE" \\\n  --dry-run=client \\\n  -o yaml > "$OUTPUT"\n\nsops --encrypt --in-place "$OUTPUT"\nprintf \'created encrypted application secret: %s\\n\' "$OUTPUT"\n'}, 'sops-create-ghcr-secret.sh': {'interpreter': 'sh', 'body': 'set -eu\n\nNAMESPACE="${NAMESPACE:-casinoshiz}"\nNAME="${NAME:-ghcr-pull}"\nOUTPUT="${OUTPUT:-clusters/production/casinoshiz/ghcr.secret.yaml}"\nGHCR_SERVER="${GHCR_SERVER:-ghcr.io}"\n\ndie() {\n  printf \'error: %s\\n\' "$*" >&2\n  exit 1\n}\n\ncommand -v kubectl >/dev/null 2>&1 || die "kubectl is required"\ncommand -v sops >/dev/null 2>&1 || die "sops is required"\n[ -f .sops.yaml ] || die ".sops.yaml missing; run ./scripts/sops-init.sh"\n[ -n "${GHCR_USERNAME:-}" ] || die "GHCR_USERNAME is required"\n[ -n "${GHCR_TOKEN:-}" ] || die "GHCR_TOKEN is required"\n\nmkdir -p "$(dirname "$OUTPUT")"\n\nkubectl create secret docker-registry "$NAME" \\\n  --namespace "$NAMESPACE" \\\n  --docker-server "$GHCR_SERVER" \\\n  --docker-username "$GHCR_USERNAME" \\\n  --docker-password "$GHCR_TOKEN" \\\n  --dry-run=client \\\n  -o yaml > "$OUTPUT"\n\nsops --encrypt --in-place "$OUTPUT"\nunset GHCR_TOKEN\n\nprintf \'created encrypted GHCR pull secret: %s\\n\' "$OUTPUT"\n'}, 'sops-encrypt.sh': {'interpreter': 'sh', 'body': 'set -eu\n\ndie() {\n  printf \'error: %s\\n\' "$*" >&2\n  exit 1\n}\n\ncommand -v sops >/dev/null 2>&1 || die "sops is required"\n[ -f .sops.yaml ] || die ".sops.yaml is missing; run ./scripts/sops-init.sh"\n\n[ "$#" -gt 0 ] || {\n  cat <<\'EOF\'\nUsage:\n  ./scripts/sops-encrypt.sh path/to/file.secret.yaml [...]\n\nEach file must be a Kubernetes Secret YAML containing data or stringData.\nThe file is encrypted in place after validation.\nEOF\n  exit 2\n}\n\nfor file in "$@"; do\n  [ -f "$file" ] || die "file not found: $file"\n\n  kind="$(awk \'$1 == "kind:" { print $2; exit }\' "$file")"\n  [ "$kind" = Secret ] || die "$file is not a Kubernetes Secret"\n\n  if grep -q \'ENC\\[AES256_GCM\' "$file"; then\n    printf \'already encrypted: %s\\n\' "$file"\n    continue\n  fi\n\n  sops --encrypt --in-place "$file"\n  grep -q \'ENC\\[AES256_GCM\' "$file" ||\n    die "encryption marker not found after encrypting $file"\n\n  printf \'encrypted: %s\\n\' "$file"\ndone\n'}, 'sops-init.sh': {'interpreter': 'sh', 'body': 'set -eu\n\nAGE_KEY_FILE="${AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"\nOUTPUT="${OUTPUT:-.sops.yaml}"\n\ndie() {\n  printf \'error: %s\\n\' "$*" >&2\n  exit 1\n}\n\ncommand -v age-keygen >/dev/null 2>&1 || die "age-keygen is required"\ncommand -v sops >/dev/null 2>&1 || die "sops is required"\n\nif [ ! -f "$AGE_KEY_FILE" ]; then\n  mkdir -p "$(dirname "$AGE_KEY_FILE")"\n  chmod 700 "$(dirname "$AGE_KEY_FILE")"\n  age-keygen -o "$AGE_KEY_FILE"\n  chmod 600 "$AGE_KEY_FILE"\nfi\n\nrecipient="$(age-keygen -y "$AGE_KEY_FILE")"\ncase "$recipient" in\n  age1*) ;;\n  *) die "invalid age recipient derived from $AGE_KEY_FILE" ;;\nesac\n\ncat > "$OUTPUT" <<EOF\ncreation_rules:\n  - path_regex: \'(^|/).*[.]secret[.]ya?ml$\'\n    encrypted_regex: \'^(data|stringData)$\'\n    age: $recipient\n\n  - path_regex: \'(^|/).*ghcr.*[.]ya?ml$\'\n    encrypted_regex: \'^(data|stringData)$\'\n    age: $recipient\nEOF\n\nprintf \'created %s for recipient %s\\n\' "$OUTPUT" "$recipient"\nprintf \'private identity remains at %s\\n\' "$AGE_KEY_FILE"\n'}}
+SCRIPTS = {'cluster-status.sh': {'interpreter': 'bash', 'body': 'set -euo pipefail\n\necho "== Nodes =="\nkubectl get nodes -o wide\n\necho\necho "== Argo CD =="\nif command -v kubectl >/dev/null 2>&1; then\n  kubectl get applications -n argocd\nelse\n  echo "Argo CD applications are not available"\nfi\n\necho\necho "== Workloads =="\nkubectl get deployments,statefulsets -A\n\necho\necho "== Pods not Running or Completed =="\nkubectl get pods -A \\\n  --field-selector=status.phase!=Running,status.phase!=Succeeded \\\n  || true\n\necho\necho "== PVCs =="\nkubectl get pvc -A\n\necho\necho "== Ingresses =="\nkubectl get ingress -A\n\necho\necho "== Certificates =="\nkubectl get certificates -A 2>/dev/null || true\n\necho\necho "== Data Jobs =="\nkubectl get cronjobs,jobs -n data\n\necho\necho "== Recent warning events =="\nkubectl get events -A \\\n  --field-selector=type=Warning \\\n  --sort-by=.lastTimestamp \\\n  | tail -n 50\n'}, 'local-cluster-create.sh': {'interpreter': 'bash', 'body': 'set -euo pipefail\n\ncluster="${K3D_CLUSTER_NAME:-casinoshiz-local}"\nregistry="k3d-casinoshiz-registry.localhost"\nregistry_port="${K3D_REGISTRY_PORT:-5005}"\n\nif ! docker info >/dev/null 2>&1; then\n  echo "Docker daemon is not available." >&2\n  exit 1\nfi\n\nif ! k3d registry list | grep -q "${registry}"; then\n  k3d registry create casinoshiz-registry.localhost \\\n    --port "${registry_port}"\nfi\n\nif ! k3d cluster list | grep -q "^${cluster}[[:space:]]"; then\n  k3d cluster create "${cluster}" \\\n    --servers 1 \\\n    --agents 0 \\\n    --registry-use "${registry}:${registry_port}" \\\n    --port "8080:80@loadbalancer" \\\n    --port "8443:443@loadbalancer" \\\n    --wait\nfi\n\nkubectl config use-context "k3d-${cluster}"\nkubectl get nodes\n'}, 'local-cluster-delete.sh': {'interpreter': 'bash', 'body': 'set -euo pipefail\n\ncluster="${K3D_CLUSTER_NAME:-casinoshiz-local}"\n\nk3d cluster delete "${cluster}" || true\n\nif [[ "${DELETE_LOCAL_REGISTRY:-false}" == "true" ]]; then\n  k3d registry delete casinoshiz-registry.localhost || true\nfi\n'}, 'local-argocd-bootstrap.sh': {'interpreter': 'bash', 'body': 'set -euo pipefail\n\nage_key_file="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"\n[[ -f "${age_key_file}" ]] || { echo "Age key not found: ${age_key_file}" >&2; exit 1; }\n\nkubectl apply -f argocd/namespace.yaml\nkubectl create secret generic sops-age \\\n  --namespace=argocd \\\n  --from-file=keys.txt="${age_key_file}" \\\n  --dry-run=client -o yaml | kubectl apply -f -\nkubectl apply -f argocd/cmp-plugin.yaml\nhelm repo add argo https://argoproj.github.io/argo-helm --force-update\nhelm repo update\nhelm upgrade --install argocd argo/argo-cd \\\n  --namespace argocd --create-namespace \\\n  --values argocd/values.yaml \\\n  --wait --timeout 15m\nkubectl apply -f argocd/project.yaml\nkubectl apply -f argocd/root-local.yaml\nkubectl get applications -n argocd\n'}, 'local-image-push.sh': {'interpreter': 'bash', 'body': 'set -euo pipefail\n\nif (($# != 2)); then\n  echo "Usage: $0 <source-image:tag> <target-repository>" >&2\n  echo "Example: $0 casinoshiz-backend:latest casinoshiz-backend" >&2\n  exit 2\nfi\n\nsource_image="$1"\ntarget_repository="$2"\nhost_registry="${LOCAL_REGISTRY_HOST:-localhost:5005}"\ntarget="${host_registry}/${target_repository}:local"\n\ndocker image inspect "${source_image}" >/dev/null\ndocker tag "${source_image}" "${target}"\ndocker push "${target}"\n\necho "Pushed ${target}"\n'}, 'manual-backup.sh': {'interpreter': 'bash', 'body': 'set -euo pipefail\n\ntimestamp="$(date +%s)"\ncronjobs=(\n  postgres-backup\n  redis-backup\n  clickhouse-backup\n  minio-backup\n)\n\njobs=()\n\nfor cronjob in "${cronjobs[@]}"; do\n  job="${cronjob}-manual-${timestamp}"\n  kubectl create job \\\n    --from="cronjob/${cronjob}" \\\n    "$job" \\\n    -n data\n  jobs+=("$job")\ndone\n\nfor job in "${jobs[@]}"; do\n  kubectl wait \\\n    --for=condition=complete \\\n    "job/${job}" \\\n    -n data \\\n    --timeout=30m\n\n  kubectl logs \\\n    "job/${job}" \\\n    -n data\ndone\n\necho "All manual backup Jobs completed."\n'}, 'post-deploy-check.sh': {'interpreter': 'bash', 'body': 'set -euo pipefail\n\nwait_timeout="${WAIT_TIMEOUT:-300s}"\n\necho "Checking Argo CD..."\nif command -v kubectl >/dev/null 2>&1; then\n  kubectl get applications -n argocd\nfi\n\necho "Waiting for data StatefulSets..."\nfor statefulset in postgres redis clickhouse minio; do\n  kubectl rollout status "statefulset/${statefulset}" \\\n    -n data \\\n    --timeout="${wait_timeout}"\ndone\n\necho "Waiting for CasinoShiz Deployments..."\nwhile IFS= read -r deployment; do\n  kubectl rollout status "$deployment" \\\n    -n casinoshiz \\\n    --timeout="${wait_timeout}"\ndone < <(kubectl get deployments -n casinoshiz -o name)\n\necho "Checking PVCs..."\nkubectl get pvc -A\n\nunbound="$(\n  kubectl get pvc -A \\\n    -o jsonpath=\'{range .items[?(@.status.phase!="Bound")]}{.metadata.namespace}/{.metadata.name}{"\\n"}{end}\'\n)"\nif [[ -n "$unbound" ]]; then\n  printf \'Unbound PVCs:\\n%s\\n\' "$unbound" >&2\n  exit 1\nfi\n\necho "Checking certificates..."\nkubectl get certificates -A\n\necho "Checking ingresses..."\nkubectl get ingress -A\n\necho "Checking backup CronJobs..."\nkubectl get cronjobs -n data\n\necho "Checking observability..."\nkubectl get pods -n monitoring\nkubectl get pods -n observability\n\necho "Checking application health from inside the cluster..."\nfor service in telegram-bff admin-bff rest-api; do\n  kubectl run "health-${service}-$(date +%s)" \\\n    --rm \\\n    --restart=Never \\\n    --image=curlimages/curl:8.12.1 \\\n    -n casinoshiz \\\n    -- \\\n    -fsS "http://${service}.casinoshiz.svc.cluster.local:8080/health/ready"\ndone\n\necho "Post-deployment checks passed."\n'}, 'preflight.sh': {'interpreter': 'bash', 'body': 'set -euo pipefail\n\nrequired=(git helm kustomize kubectl go-task ansible-playbook)\nmissing=()\n\nfor tool in "${required[@]}"; do\n  if ! command -v "$tool" >/dev/null 2>&1; then\n    missing+=("$tool")\n  fi\ndone\n\nif ((${#missing[@]} > 0)); then\n  printf \'Missing required tools: %s\\n\' "${missing[*]}" >&2\n  exit 1\nfi\n\nif [[ ! -f Taskfile.yml ]]; then\n  echo "Run this script from the repository root." >&2\n  exit 1\nfi\n\necho "Validating repository..."\ngo-task clean\ngo-task validate\n\necho "Checking unresolved placeholders..."\nplaceholders="$(git grep -n CHANGE_ME || true)"\nif [[ -n "$placeholders" ]]; then\n  printf \'%s\\n\' "$placeholders"\n  echo "Unresolved CHANGE_ME values remain." >&2\n  exit 1\nfi\n\necho "Checking repository state..."\nif [[ -n "$(git status --porcelain)" ]]; then\n  git status --short\n  echo "Working tree is not clean." >&2\n  exit 1\nfi\n\necho "Checking Kubernetes access..."\nkubectl version --client\nkubectl cluster-info\nkubectl get nodes\n\necho "Preflight passed."\n'}, 'restore-clickhouse.sh': {'interpreter': 'sh', 'body': 'set -eu\n\nset -eu\n\nNAMESPACE="${NAMESPACE:-data}"\nBACKUP_PVC="${BACKUP_PVC:-data-backups}"\n\ndie() {\n  printf \'error: %s\n\' "$*" >&2\n  exit 1\n}\n\ninfo() {\n  printf \'==> %s\n\' "$*"\n}\n\nrequire_command() {\n  command -v "$1" >/dev/null 2>&1 || die "missing command: $1"\n}\n\nlatest_backup_dir() {\n  kind="$1"\n  kubectl -n "$NAMESPACE" run "backup-lister-$$" \\\n    --restart=Never \\\n    --image=alpine:3.22 \\\n    --overrides="$(\n      cat <<JSON\n{\n  "spec": {\n    "containers": [{\n      "name": "lister",\n      "image": "alpine:3.22",\n      "command": ["/bin/sh", "-ec", "find /backup/$kind -mindepth 1 -maxdepth 1 -type d -printf \'%f\\n\' | sort | tail -n 1"],\n      "volumeMounts": [{"name": "backups", "mountPath": "/backup"}]\n    }],\n    "volumes": [{"name": "backups", "persistentVolumeClaim": {"claimName": "$BACKUP_PVC"}}]\n  }\n}\nJSON\n    )" >/dev/null\n\n  kubectl -n "$NAMESPACE" wait \\\n    --for=jsonpath=\'{.status.phase}\'=Succeeded \\\n    "pod/backup-lister-$$" \\\n    --timeout=90s >/dev/null\n\n  result="$(kub