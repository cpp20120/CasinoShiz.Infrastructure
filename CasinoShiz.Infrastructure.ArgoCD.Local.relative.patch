d kubectl\n\nBACKUP="${BACKUP:-latest}"\nSOURCE_BUCKET="${SOURCE_BUCKET:-}"\nTARGET_BUCKET="${TARGET_BUCKET:-}"\nOVERWRITE="${OVERWRITE:-false}"\nKEEP_JOB="${KEEP_JOB:-false}"\n\nusage() {\n  cat <<\'EOF\'\nUsage:\n  restore-minio.sh --bucket NAME [options]\n\nOptions:\n  --backup NAME          Backup directory or "latest".\n  --bucket NAME          Source bucket directory inside the backup.\n  --target-bucket NAME   Destination bucket. Defaults to a timestamped name.\n  --overwrite            Allow mirroring into an existing target bucket.\n  --keep-job             Keep the Job.\n\nBy default this restores into a new bucket and does not overwrite production.\nEOF\n}\n\nwhile [ "$#" -gt 0 ]; do\n  case "$1" in\n    --backup) BACKUP="$2"; shift 2 ;;\n    --bucket) SOURCE_BUCKET="$2"; shift 2 ;;\n    --target-bucket) TARGET_BUCKET="$2"; shift 2 ;;\n    --overwrite) OVERWRITE=true; shift ;;\n    --keep-job) KEEP_JOB=true; shift ;;\n    -h|--help) usage; exit 0 ;;\n    *) die "unknown argument: $1" ;;\n  esac\ndone\n\n[ -n "$SOURCE_BUCKET" ] || die "--bucket is required"\n\nif [ "$BACKUP" = latest ]; then\n  BACKUP="$(latest_backup_dir minio)"\nfi\n\nif [ -z "$TARGET_BUCKET" ]; then\n  TARGET_BUCKET="${SOURCE_BUCKET}-restore-$(date -u +%Y%m%d%H%M%S)"\nfi\n\nJOB="minio-restore-$(date +%s)"\nMIRROR_FLAG=""\nif [ "$OVERWRITE" = true ]; then\n  MIRROR_FLAG="--overwrite"\nfi\n\ninfo "Restoring MinIO bucket $SOURCE_BUCKET from $BACKUP into $TARGET_BUCKET"\n\ncat <<YAML | kubectl apply -f -\napiVersion: batch/v1\nkind: Job\nmetadata:\n  name: $JOB\n  namespace: $NAMESPACE\nspec:\n  backoffLimit: 0\n  ttlSecondsAfterFinished: 3600\n  template:\n    spec:\n      restartPolicy: Never\n      containers:\n        - name: restore\n          image: minio/mc:RELEASE.2025-08-13T08-35-41Z\n          env:\n            - name: MINIO_ROOT_USER\n              valueFrom:\n                secretKeyRef:\n                  name: data-secrets\n                  key: minio-root-user\n            - name: MINIO_ROOT_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: data-secrets\n                  key: minio-root-password\n          command:\n            - /bin/sh\n            - -ec\n            - |\n              src="/backup/minio/$BACKUP/$SOURCE_BUCKET"\n              test -d "\\$src"\n\n              mc alias set target \\\n                http://minio.data.svc.cluster.local:9000 \\\n                "\\$MINIO_ROOT_USER" \\\n                "\\$MINIO_ROOT_PASSWORD"\n\n              if mc stat "target/$TARGET_BUCKET" >/dev/null 2>&1; then\n                test "$OVERWRITE" = true || {\n                  echo "target bucket already exists: $TARGET_BUCKET" >&2\n                  exit 1\n                }\n              else\n                mc mb "target/$TARGET_BUCKET"\n              fi\n\n              mc mirror $MIRROR_FLAG "\\$src" "target/$TARGET_BUCKET"\n\n              local_count="\\$(find "\\$src" -type f | wc -l | tr -d \' \')"\n              remote_count="\\$(mc find "target/$TARGET_BUCKET" --type f | wc -l | tr -d \' \')"\n              test "\\$remote_count" -ge "\\$local_count"\n              echo "restored bucket=$TARGET_BUCKET objects=\\$remote_count"\n          volumeMounts:\n            - name: backups\n              mountPath: /backup\n              readOnly: true\n      volumes:\n        - name: backups\n          persistentVolumeClaim:\n            claimName: $BACKUP_PVC\nYAML\n\nwait_job "$JOB" 1800s\n\nif [ "$KEEP_JOB" != true ]; then\n  kubectl -n "$NAMESPACE" delete job "$JOB" --wait=false >/dev/null\nfi\n\ninfo "MinIO restore completed: $TARGET_BUCKET"\n'}, 'restore-postgres.sh': {'interpreter': 'sh', 'body': 'set -eu\n\nset -eu\n\nNAMESPACE="${NAMESPACE:-data}"\nBACKUP_PVC="${BACKUP_PVC:-data-backups}"\n\ndie() {\n  printf \'error: %s\n\' "$*" >&2\n  exit 1\n}\n\ninfo() {\n  printf \'==> %s\n\' "$*"\n}\n\nrequire_command() {\n  command -v "$1" >/dev/null 2>&1 || die "missing command: $1"\n}\n\