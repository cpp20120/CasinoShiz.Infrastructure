diff -ruN '--exclude=.git' '--exclude=.task' a/argocd/applications/local/otel-collector.yaml b/argocd/applications/local/otel-collector.yaml
--- a/argocd/applications/local/otel-collector.yaml	1970-01-01 00:00:00.000000000 +0000
+++ b/argocd/applications/local/otel-collector.yaml	2026-07-17 18:53:04.431093008 +0000
@@ -0,0 +1,63 @@
+apiVersion: argoproj.io/v1alpha1
+kind: Application
+metadata:
+  name: local-otel-collector
+  namespace: argocd
+  annotations:
+    argocd.argoproj.io/sync-wave: "40"
+spec:
+  project: casinoshiz
+  source:
+    repoURL: https://open-telemetry.github.io/opentelemetry-helm-charts
+    chart: opentelemetry-collector
+    targetRevision: '*'
+    helm:
+      releaseName: opentelemetry-collector
+      valuesObject:
+        mode: deployment
+        replicaCount: 1
+        image:
+          repository: otel/opentelemetry-collector-contrib
+        command:
+          name: otelcol-contrib
+        config:
+          receivers:
+            otlp:
+              protocols:
+                grpc:
+                  endpoint: 0.0.0.0:4317
+                http:
+                  endpoint: 0.0.0.0:4318
+          processors:
+            memory_limiter:
+              check_interval: 5s
+              limit_percentage: 75
+              spike_limit_percentage: 15
+            batch: {}
+          exporters:
+            otlp/tempo:
+              endpoint: tempo.observability.svc.cluster.local:4317
+              tls:
+                insecure: true
+          service:
+            pipelines:
+              traces:
+                receivers: [otlp]
+                processors: [memory_limiter, batch]
+                exporters: [otlp/tempo]
+        ports:
+          otlp:
+            enabled: true
+          otlp-http:
+            enabled: true
+  destination:
+    server: https://kubernetes.default.svc
+    namespace: observability
+  syncPolicy:
+    automated:
+      prune: true
+      selfHeal: true
+    syncOptions:
+      - CreateNamespace=true
+      - PruneLast=true
+      - ServerSideApply=true
diff -ruN '--exclude=.git' '--exclude=.task' a/argocd/applications/local/tempo.yaml b/argocd/applications/local/tempo.yaml
--- a/argocd/applications/local/tempo.yaml	1970-01-01 00:00:00.000000000 +0000
+++ b/argocd/applications/local/tempo.yaml	2026-07-17 18:53:03.313215375 +0000
@@ -0,0 +1,37 @@
+apiVersion: argoproj.io/v1alpha1
+kind: Application
+metadata:
+  name: local-tempo
+  namespace: argocd
+  annotations:
+    argocd.argoproj.io/sync-wave: "20"
+spec:
+  project: casinoshiz
+  source:
+    repoURL: https://grafana-community.github.io/helm-charts
+    chart: tempo
+    targetRevision: '*'
+    helm:
+      releaseName: tempo
+      valuesObject:
+        replicas: 1
+        tempo:
+          reportingEnabled: false
+          retention: 24h
+          receivers:
+            otlp:
+              protocols:
+                grpc: { endpoint: 0.0.0.0:4317 }
+                http: { endpoint: 0.0.0.0:4318 }
+          storage:
+            trace:
+              backend: local
+              local: { path: /var/tempo/traces }
+              wal: { path: /var/tempo/wal }
+        persistence: { enabled: false }
+  destination:
+    server: https://kubernetes.default.svc
+    namespace: observability
+  syncPolicy:
+    automated: { prune: true, selfHeal: true }
+    syncOptions: [CreateNamespace=true, PruneLast=true, ServerSideApply=true]
