ERY=""\nif [ "$DROP_TARGET" = true ]; then\n  DROP_QUERY="DROP DATABASE IF EXISTS \\\\\\`$TARGET_DATABASE\\\\\\`;"\nfi\n\ninfo "Restoring ClickHouse $SOURCE_DATABASE from $BACKUP into $TARGET_DATABASE"\n\ncat <<YAML | kubectl apply -f -\napiVersion: batch/v1\nkind: Job\nmetadata:\n  name: $JOB\n  namespace: $NAMESPACE\nspec:\n  backoffLimit: 0\n  ttlSecondsAfterFinished: 3600\n  template:\n    spec:\n      restartPolicy: Never\n      containers:\n        - name: restore\n          image: clickhouse/clickhouse-server:24.8-alpine\n          env:\n            - name: CLICKHOUSE_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: data-secrets\n                  key: clickhouse-password\n          command:\n            - /bin/sh\n            - -ec\n            - |\n              client() {\n                clickhouse-client \\\n                  --host clickhouse.data.svc.cluster.local \\\n                  --password "\\$CLICKHOUSE_PASSWORD" \\\n                  --multiquery \\\n                  --query "\\$1"\n              }\n\n              client "$DROP_QUERY"\n\n              existing="\\$(clickhouse-client \\\n                --host clickhouse.data.svc.cluster.local \\\n                --password "\\$CLICKHOUSE_PASSWORD" \\\n                --query "EXISTS DATABASE \\\\\\`$TARGET_DATABASE\\\\\\`")"\n              test "\\$existing" = 0 || {\n                echo "target database already exists: $TARGET_DATABASE" >&2\n                exit 1\n              }\n\n              client "RESTORE DATABASE \\\\\\`$SOURCE_DATABASE\\\\\\`\n                AS \\\\\\`$TARGET_DATABASE\\\\\\`\n                FROM Disk(\'backup\', \'$BACKUP\')"\n\n              tables="\\$(clickhouse-client \\\n                --host clickhouse.data.svc.cluster.local \\\n                --password "\\$CLICKHOUSE_PASSWORD" \\\n                --query "SELECT count() FROM system.tables WHERE database = \'$TARGET_DATABASE\'")"\n              test "\\$tables"