apiVersion: v1
kind: Secret
metadata:
  name: casinoshiz-secrets
  namespace: casinoshiz
type: Opaque
stringData:
    backend-postgres-connection-string: Host=postgres.data.svc.cluster.local;Port=5432;Database=backend;Username=backend;Password=CHANGE_ME;Maximum Pool Size=10;Timeout=15;Command Timeout=30
    identity-postgres-connection-string: Host=postgres.data.svc.cluster.local;Port=5432;Database=identity;Username=identity;Password=CHANGE_ME;Maximum Pool Size=10;Timeout=15;Command Timeout=30
    wallet-postgres-connection-string: Host=postgres.data.svc.cluster.local;Port=5432;Database=wallet;Username=wallet;Password=CHANGE_ME;Maximum Pool Size=10;Timeout=15;Command Timeout=30
  redis-connection-string: redis.data.svc.cluster.local:6379,password=CHANGE_ME
  clickhouse-password: CHANGE_ME
  operations-api-key: CHANGE_ME
  telegram-bot-token: CHANGE_ME
  admin-web-token: CHANGE_ME
  # Add real application keys expected by your configuration, for example:
  # telegram-bot-token: CHANGE_ME
  # admin-web-token: CHANGE_ME
